{
    "name": "sumai",
    "displayName": "Sumai",
    "version": "0.0.1",
    "description": "An Browser extension to summarize long content to your native language using LLM AI",
    "author": "tnguyen_dev",
    "scripts": {
        "dev": "plasmo dev --auto-reload",
        "build": "plasmo build",
        "package": "plasmo package"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.9",
        "@heroicons/react": "^2.2.0",
        "dompurify": "^3.3.0",
        "highlight.js": "^11.11.1",
        "lucide-react": "^0.553.0",
        "marked": "^17.0.0",
        "marked-highlight": "^2.2.3",
        "prism-react-renderer": "^2.4.1",
        "react": "18.2.0",
        "react-copy-to-clipboard": "^5.1.0",
        "react-dom": "18.2.0",
        "react-error-boundary": "^6.0.0",
        "react-tooltip": "^5.30.0",
        "unified": "^10.1.2",
        "vfile": "^5.3.7",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.1.1",
        "@types/chrome": "0.0.258",
        "@types/node": "20.11.5",
        "@types/react": "18.2.48",
        "@types/react-dom": "18.2.18",
        "@types/react-syntax-highlighter": "^15.5.13",
        "autoprefixer": "^10.4.22",
        "plasmo": "^0.90.5",
        "postcss": "^8.5.6",
        "prettier": "^3.2.4",
        "tailwindcss": "^3.4.18",
        "typescript": "5.3.3"
    },
    "manifest": {
        "permissions": [
            "storage",
            "activeTab",
            "tabs",
            "scripting"
        ],
        "host_permissions": [
            "https://*/*",
            "<all_urls>"
        ]
    }
}
